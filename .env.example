# ─── Kotlin API (apps/api) ───────────────────────────────────
PORT=8080
PUBLIC_URL=http://localhost:8080

# PostgreSQL — get from Supabase → Settings → Database → Connection string
DATABASE_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_POOL_SIZE=10

# Webhook HMAC secret — any random string, same value shared with agents
WEBHOOK_SECRET=change_me_to_a_random_string

# Matching
MATCH_MIN_SCORE=40

# ─── Next.js Web (apps/web) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# For production:
# NEXT_PUBLIC_API_URL=https://agentmesh-api.fly.dev
